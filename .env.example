# ─── Expo 앱 (번들에 포함됨 — 비밀에 쓰지 말 것) ───
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_EAS_PROJECT_ID=

# 프록시 공개 URL (로컬: http://localhost:8787 / 실기기: http://<PC_LAN_IP>:8787 / 배포: https://...)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
# 프록시와 동일한 값이면 요청 시 x-proxy-token 헤더로 전달 (프로덕션 권장)
EXPO_PUBLIC_PROXY_TOKEN=

# 선택: Sentry DSN (에러 대시보드)
EXPO_PUBLIC_SENTRY_DSN=

# 선택: 커스텀 모니터링 POST URL
EXPO_PUBLIC_MONITORING_ENDPOINT=

# ─── proxy-server 전용 (.env 루트에서 `npm run proxy:start` 시 함께 로드) ───
# 아래 키는 클라이언트에 넣지 말고 서버/배포 환경에만 둡니다.

OPENAI_API_KEY=
NAVER_SHOPPING_CLIENT_ID=
NAVER_SHOPPING_CLIENT_SECRET=
OPENWEATHER_API_KEY=
REPLICATE_API_TOKEN=

# 서버가 요구하는 프록시 토큰 (EXPO_PUBLIC_PROXY_TOKEN 과 동일 권장)
PROXY_TOKEN=

# 프로덕션: 쉼표로 Origin 허용 목록 (비우면 개발 편의상 전체 허용과 유사 동작)
# 예: https://expo.dev,exp://192.168.0.10:8081
CORS_ALLOWED_ORIGINS=

# 선택: 배포 시 /health JSON에 표시
PROXY_VERSION=1
